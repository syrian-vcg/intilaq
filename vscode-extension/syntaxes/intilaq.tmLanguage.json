{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "丕賱丕賳胤賱丕賯",
    "scopeName": "source.intilaq",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#literals" },
        { "include": "#keywords" },
        { "include": "#braces" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.intilaq",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.intilaq",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.intilaq",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.intilaq",
                    "match": "(?<![\\p{L}_])-?\\d+(\\.\\d+)?(?![\\p{L}_])"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.language.boolean.intilaq",
                    "match": "(?<![\\p{L}_])(氐丨賷丨|禺丕胤卅)(?![\\p{L}_])"
                },
                {
                    "name": "constant.language.null.intilaq",
                    "match": "(?<![\\p{L}_])(賮乇丕睾)(?![\\p{L}_])"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.intilaq",
                    "match": "(?<![\\p{L}_])(丕爻賲|賲毓乇賮|賲噩賲賵毓丞|丨賱賯丞|鬲毓乇賷賮|丨丕噩夭|賳氐|賰鬲賱丞|賰丕卅賳|賯氐|賱氐賯|賳賯賱|鬲賵乇賷丿|鬲氐丿賷乇|鬲賳夭賷賱|胤亘丕毓丞|噩賲毓|賯爻賲|鬲乇噩賲丞|賮賯乇丞|禺丕賳丞|氐賮|賴賳丕|丕卮毓丕乇|亘乇賷丿|鬲爻賲賷丞|丨丿孬|賳噩丨|禺胤丕亍)(?![\\p{L}_])"
                }
            ]
        },
        "braces": {
            "patterns": [
                {
                    "name": "punctuation.section.block.intilaq",
                    "match": "[{}]"
                },
                {
                    "name": "keyword.operator.assignment.intilaq",
                    "match": "="
                }
            ]
        }
    }
}
